{
  "name": "tw-overlay",
  "version": "1.12.0",
  "description": "TalesWeaver Companion Browser",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && node scripts/copy-resources.js",
    "build:native": "node-gyp configure build --directory native",
    "rebuild:native": "electron-rebuild -f -w tw_native --module-dir native",
    "start": "npm run build && electron .",
    "only-dev": "electron . --dev",
    "dev": "npm run build && electron . --dev",
    "dist": "npm run build && electron-builder --win",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.filbertlab.twoverlay",
    "productName": "twOverlay",
    "directories": {
      "output": "dist_electron"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "drt0927",
        "repo": "tw-overlay"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/koffi/**",
      "native/build/Release/**"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "src/icons/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "files": [
      "dist/**/*",
      "dist/assets/**/*",
      "package.json",
      "node_modules/**/*",
      "native/build/Release/**"
    ]
  },
  "keywords": [],
  "author": "filbertlab",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.8.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "iconv-lite": "^0.7.2",
    "koffi": "^2.15.1",
    "tail": "^2.2.6"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.4",
    "@types/tail": "^2.2.3",
    "electron": "^40.4.0",
    "electron-builder": "^26.7.0",
    "electron-rebuild": "^3.2.9",
    "node-addon-api": "^8.7.0",
    "node-gyp": "^11.5.0",
    "typescript": "^5.7.3"
  },
  "binary": {
    "module_name": "tw_native",
    "module_path": "./native/build/Release/",
    "host": "https://github.com/drt0927/tw-overlay/releases/download/"
  }
}
